# =============================================
# KUIZARD — Variables d'environnement (exemple)
# =============================================
# Copier ce fichier en .env.local pour le dev :
#   cp .env.example .env.local
# Ne JAMAIS committer .env.local — il contient les vrais secrets.

# -----------------------------------------
# BASE DE DONNÉES (PostgreSQL via Docker)
# -----------------------------------------
# Ces 3 variables sont lues par docker-compose.yml ET par DATABASE_URL ci-dessous.
# En prod, mettre un POSTGRES_PASSWORD solide (openssl rand -base64 24).
POSTGRES_USER=kuizard
POSTGRES_PASSWORD=kuizard_dev_pwd
POSTGRES_DB=kuizard_dev

DATABASE_URL="postgresql://kuizard:kuizard_dev_pwd@localhost:5432/kuizard_dev?schema=public"

# -----------------------------------------
# NEXT.JS / APP
# -----------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kuizard"

# -----------------------------------------
# AUTH.JS (NextAuth v5)
# -----------------------------------------
# Générer avec : openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-random-string-here"
AUTH_URL="http://localhost:3000"

# Google OAuth (optionnel — voir https://console.cloud.google.com/apis/credentials)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -----------------------------------------
# STRIPE (mode test pour le dev)
# -----------------------------------------
# Récupérer sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -----------------------------------------
# EMAIL (Resend, pour les emails transactionnels)
# -----------------------------------------
# Créer un compte sur https://resend.com — gratuit 3000 emails/mois
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@kuizard.fr"

# -----------------------------------------
# STOCKAGE FICHIERS (Cloudflare R2)
# -----------------------------------------
# À configurer plus tard, quand on ajoutera l'upload d'images
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="kuizard-uploads"
# R2_PUBLIC_URL="https://media.kuizard.fr"
