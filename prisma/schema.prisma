// ====================================================
// KUIZARD — Schéma Prisma initial
// ====================================================
// Documentation : https://pris.ly/d/prisma-schema
// Pour appliquer une modif après édition :
//   npx prisma migrate dev --name <nom_de_la_migration>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================
// AUTH.JS — Modèles requis par @auth/prisma-adapter
// ====================================================

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String      @unique
  emailVerified    DateTime?
  image            String?
  // Hash bcrypt pour le provider Credentials (email/password).
  // Null si l'utilisateur s'est inscrit uniquement via OAuth (Google, etc.).
  passwordHash     String?
  accountType      AccountType @default(INDIVIDUAL)
  // Rôle global : USER par défaut, ADMIN pour les comptes staff.
  role             UserRole    @default(USER)
  stripeCustomerId String?     @unique

  // ====== Comptes professionnels (BUSINESS) ======
  // Champs collectés pour la facturation B2B (apparaissent sur les factures Stripe).
  // Le SIRET est validé par algorithme Luhn + (idéalement) appel API recherche-entreprises.
  // Tous nullable pour rester compatible avec les comptes existants.
  siret            String?     // 14 chiffres
  companyName      String?     // Raison sociale officielle
  vatNumber        String?     // N° TVA intracom optionnel

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  // Date de la dernière connexion réussie (mise à jour côté signin).
  // Sert au cron de suppression auto des comptes inactifs (> 3 ans).
  // Si null : on retombe sur createdAt.
  lastLoginAt      DateTime?
  // Date d'envoi du dernier avertissement "compte sera supprimé dans 30j"
  inactivityWarnedAt DateTime?

  // Dernière version des CGU/CGV acceptée par l'utilisateur. Si différent
  // de CURRENT_TERMS_VERSION (lib/legal/terms-version.ts), on redirige vers
  // /accept-terms à la prochaine action. Format : "YYYY-MM-DD".
  lastAcceptedTermsVersion String?

  // ====== Modération / Bannissement ======
  // Conformément à la clause "Modération et suspension" des CGU §4, Projiat
  // peut suspendre ou résilier un compte. On garde l'historique (qui a banni,
  // quand, pourquoi) pour pouvoir justifier la sanction si besoin.
  bannedAt         DateTime?
  bannedReason     String?      // raison interne (visible dans l'admin)
  bannedBy         String?      // id de l'admin qui a banni

  accounts         Account[]
  sessions         Session[]
  quizzes          Quiz[]
  conversations    Conversation[]
  payments         Payment[]
  subscriptions    Subscription[]
  termsAcceptances TermsAcceptance[]
  grantedPlans     GrantedPlan[]
}

// ====================================================
// QUIZZ DE LA SEMAINE — featured public, gratuit, à lots
// ====================================================
// Géré entièrement côté admin. Un seul "Quizz de la semaine" actif à la fois
// (le plus récent dont weekStart <= now() < weekEnd). Pas de paiement requis
// pour y jouer. L'admin renseigne les lots à gagner et la deadline.

model WeeklyFeaturedQuiz {
  id          String   @id @default(cuid())
  quizId      String   @unique  // référence au Quiz existant en BDD
  title       String              // titre affiché sur la home (peut différer)
  subtitle    String?             // accroche courte
  prizesText  String              // descriptif libre des lots à gagner
  weekStart   DateTime            // date d'ouverture
  weekEnd     DateTime            // date de clôture (et tirage)

  ctaLabel    String?  @default("🎁 Tenter ma chance")

  featuredBy  String              // id de l'admin qui a featuré
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weekStart, weekEnd])
  @@index([quizId])
}

// ====================================================
// CADEAUX ADMIN — plans offerts par un admin à un user
// ====================================================
// Permet à un admin d'offrir un palier payant à un user (typiquement pour
// les amis ou les early adopters) sans passer par Stripe. Le code de gating
// (lib/plans/gating.ts) regarde aussi cette table en plus de Payment et
// Subscription pour déterminer les limites d'un quiz.

model GrantedPlan {
  id          String   @id @default(cuid())
  userId      String
  planSlug    String   // ex: "festive", "magic", "bar_essentiel", "bar_pro"

  // "one_shot" → le plan s'applique à un quiz précis (quizId requis)
  // "subscription" → durée en mois, le plan s'applique à TOUS les quiz du user
  //                  pendant cette période (quizId = null)
  type        String   // "one_shot" | "subscription"
  quizId      String?  // pour one_shot uniquement

  // Pour les subscriptions offertes : période de validité
  startsAt    DateTime @default(now())
  endsAt      DateTime?  // null = pas d'échéance (rare)

  // Trace administrative
  grantedBy   String     // id de l'admin qui a octroyé
  reason      String?    // raison (note interne)
  createdAt   DateTime   @default(now())

  // Si l'admin révoque, on garde la ligne mais on marque la date
  revokedAt   DateTime?
  revokedBy   String?
  revokeReason String?

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([type])
  @@index([endsAt])
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ====================================================
// KUIZARD — Modèles métier
// ====================================================

model Quiz {
  id                String     @id @default(cuid())
  userId            String

  code              String     @unique
  title             String
  description       String?    @db.Text
  coverImageUrl     String?

  // Thème visuel (couleurs, police, fond) par-dessus le thème Kuizard
  theme             Json       @default("{}")
  // Paramètres divers (timer par question, mélange, score visible, show_leaderboard_publicly…)
  settings          Json       @default("{}")

  // Mode de pilotage : créneau horaire ou pilotage manuel par l'admin
  mode              QuizMode   @default(LIVE_MANUAL)
  scheduledOpenAt   DateTime?
  scheduledCloseAt  DateTime?

  // État temps réel du quizz (question active, pause, etc.)
  liveState         Json       @default("{}")

  // Plan utilisé pour ce quizz, détermine les limites
  plan              Plan       @default(FREE)
  isPaid            Boolean    @default(false)

  // Lots associés au classement (array de {rank, label, description, image_url})
  prizes            Json?
  // Mot de fin personnalisé (plan Magique)
  finalMessage      String?    @db.Text

  // ====== Banque de quizz (admin) ======
  // Distinct des templates (qui sont juste des structures/thèmes vides).
  // Un quiz "isLibrary" est un quiz COMPLET (questions, réponses, photos)
  // qu'un user peut DUPLIQUER dans son propre compte pour l'utiliser tel quel
  // ou le modifier. Géré côté admin via /admin/quizzes ou le dashboard normal.
  isLibrary         Boolean    @default(false)
  // Description courte pour le browser library côté user
  libraryDescription String?   @db.Text
  // Tags pour le filtre côté user (array de string)
  libraryTags       String[]   @default([])
  // Langue principale du quiz library (pour filtre user)
  libraryLanguage   String?

  status            QuizStatus @default(DRAFT)
  expiresAt         DateTime?

  // Slug du template utilisé à la création (null si quizz vierge)
  // Sert au tracking "templates déjà utilisés" côté browser
  fromTemplateSlug  String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions         Question[]
  participations    Participation[]

  @@index([userId])
  @@index([code])
  @@index([status])
}

enum QuizMode {
  SCHEDULED
  LIVE_MANUAL
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  RUNNING
  FINISHED
  ARCHIVED
}

enum Plan {
  FREE
  ESSENTIEL
  FESTIF
  MAGIQUE
  BAR_ESSENTIEL
  BAR_PRO
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  order        Int
  type         QuestionType
  text         String       @db.Text
  imageUrl     String?
  // Options (choix) : array de {label, isCorrect} pour QCM, vide pour TEXT
  options      Json         @default("[]")
  points       Int          @default(1)
  timerSeconds Int?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([quizId, order])
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  TEXT
}

// ====================================================
// SUGGESTIONS — Boîte à idées / signalements utilisateurs
// ====================================================

model Suggestion {
  id        String   @id @default(cuid())
  category  String?  // "bug" | "feature" | "design" | "other"
  message   String   @db.Text
  email     String?
  userId    String?  // si l'utilisateur est connecté
  status    String   @default("new") // "new" | "seen" | "done" | "wont_fix"

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

// ====================================================
// MONETIZATION — Plans, paiements, abos, codes promos
// ====================================================
//
// Architecture :
// - PlanConfig : config dynamique des plans (modifiable par admin)
// - Payment : historique paiements one-shot (par quizz)
// - Subscription : abos Pro/Bar récurrents
// - PromoCode : codes de réduction synchronisés avec Stripe Coupons

model PlanConfig {
  id              String   @id @default(cuid())
  // Slug stable utilisé par le code ("essentiel", "festif", "magique", "bar_essentiel", "bar_pro")
  slug            String   @unique
  name            String   // "Essentiel", "Bar Pro", etc.
  tagline         String?  // courte phrase d'accroche
  description     String?  @db.Text

  // "one_shot" : paiement à l'usage (par quizz)
  // "subscription" : abonnement récurrent
  type            String   @default("one_shot")
  // Pour les subscriptions : "month" | "year" ; null sinon
  interval        String?

  // Prix en centimes EUR (ex: 500 = 5,00 €)
  priceCents      Int      @default(0)

  // Stripe Price ID (créé manuellement dans Stripe puis collé ici)
  stripePriceId   String?

  // Limites et features. Schéma libre, ex :
  // { "maxQuestions": 10, "maxParticipants": 100,
  //   "customColors": true, "customPrizes": false,
  //   "finalMessage": true, "coverImage": true,
  //   "questionImages": true, "scheduledMode": true,
  //   "liveMode": false, "ranking": true, "tvDisplay": false }
  limits          Json     @default("{}")

  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  // Mis en avant sur la page tarifs
  isHighlighted   Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([type, isActive])
}

model PromoCode {
  id              String   @id @default(cuid())
  // Code que le user tape, normalisé en uppercase
  code            String   @unique
  description     String?

  // Une seule des deux est renseignée (null = autre type)
  percentOff      Int?     // 1-100
  amountOffCents  Int?     // ex : 500 = 5€

  // Stripe coupon ID synchronisé via API
  stripeCouponId  String?

  // Limiter à un plan, null = applicable à tous les plans
  planSlug        String?

  // Code "cadeau" : si renseigné, ce code débloque DIRECTEMENT un quizz
  // avec ce plan, sans passer par Stripe (utile pour offrir, partenariats…)
  giftPlanSlug    String?

  maxRedemptions  Int?     // null = illimité
  redemptions     Int      @default(0)
  expiresAt       DateTime?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        Payment[]

  @@index([code])
  @@index([isActive])
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String?
  quizId                String?

  // Stripe IDs
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?

  amountCents           Int
  currency              String   @default("eur")
  planSlug              String?  // plan acheté
  promoCodeId           String?

  // "pending" | "succeeded" | "failed" | "refunded"
  status                String   @default("pending")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  promoCode             PromoCode? @relation(fields: [promoCodeId], references: [id])

  @@index([userId])
  @@index([quizId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planSlug             String

  // Stripe IDs
  stripeSubscriptionId String?   @unique
  stripePriceId        String?

  // "active" | "past_due" | "canceled" | "trialing" | "incomplete"
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  endedAt              DateTime?

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ====================================================
// ACCEPTATION DES CGU/CGV — historique pour preuve juridique
// ====================================================
// Une ligne par acceptation explicite (à l'inscription, ou via /accept-terms
// après bump de CURRENT_TERMS_VERSION). On garde toutes les acceptations pour
// pouvoir prouver qu'à telle date, l'utilisateur a accepté telle version.

model TermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  termsVersion String   // ex: "2026-06-11"
  acceptedAt   DateTime @default(now())
  ipAddress    String?  // IP au moment de l'acceptation (preuve)
  userAgent    String?  // User-Agent au moment de l'acceptation

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([termsVersion])
  @@index([acceptedAt(sort: Desc)])
}

// ====================================================
// TEMPLATES — Modèles de quizz prédéfinis (CRUD admin)
// ====================================================
// Remplace progressivement le hardcoded TypeScript de lib/quiz/templates.ts

model QuizTemplate {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  category        String   // "mariage" | "anniversaire" | "team_building" | etc.
  // Langue du template : "fr" | "en" | "es" | "it" | "de" | "pt" | "ru" | "zh"
  // Si un même template existe en plusieurs langues, on duplique avec
  // slug différent (ex: "mariage-fr", "mariage-en")
  language        String   @default("fr")
  // Thème visuel principal — string libre, peut référencer un slug de Theme
  theme           String?
  // Tags libres pour filtres user (ex: "famille", "humour", "culture g.", "blind-test")
  tags            String[] @default([])
  coverImageUrl   String?

  // Définition complète des questions : array de
  // { type, text, points, options: [{ label, isCorrect }] }
  questions       Json     @default("[]")

  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, isActive])
}

// ====================================================
// PUBLIC STATS — Affichage global des chiffres clés
// ====================================================
// Singleton (id = "singleton") : un seul enregistrement, configurable par l'admin

model PublicStatsConfig {
  id                  String   @id @default("singleton")
  enabled             Boolean  @default(false)
  showUsers           Boolean  @default(true)
  showQuizzes         Boolean  @default(true)
  showQuestions       Boolean  @default(false)
  showParticipations  Boolean  @default(true)
  showAvgScore        Boolean  @default(false)
  customTitle         String?  // ex: "Kuizard en chiffres"
  customSubtitle      String?

  updatedAt           DateTime @updatedAt
}

// ====================================================
// MESSAGERIE — Conversations user ↔ admin (support intégré)
// ====================================================

model Conversation {
  id            String   @id @default(cuid())
  userId        String
  subject       String
  status        String   @default("open") // "open" | "closed"
  lastMessageAt DateTime @default(now())
  // Flags de "non lu" pour afficher des badges sans recalculer à chaque request
  unreadByAdmin Boolean  @default(true)
  unreadByUser  Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([userId])
  @@index([status, lastMessageAt(sort: Desc)])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  // Rôle de l'expéditeur — pas une FK pour permettre une réponse "support" sans
  // lier à un user admin précis (multi-admins supportés sans complication)
  senderRole     String   // "USER" | "ADMIN"
  body           String   @db.Text

  createdAt      DateTime  @default(now())
  // Read receipts : à quelle date+heure le destinataire a-t-il vu le message.
  // Pour un message USER → ADMIN, on remplit readByAdminAt à la première lecture.
  // Pour un message ADMIN → USER, on remplit readByUserAt à la première lecture.
  readByAdminAt  DateTime?
  readByUserAt   DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Participation {
  id                   String    @id @default(cuid())
  quizId               String
  nickname             String
  email                String?
  // Réponses par question : { [questionId]: { selectedOptionIds: [], textAnswer: "..." } }
  answers              Json      @default("{}")
  score                Int       @default(0)
  // Index de la question en cours pour reprendre la session après fermeture du navigateur
  currentQuestionIndex Int       @default(0)

  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  // Dernière modification (pour debug + tri "en cours")
  lastActivityAt       DateTime  @default(now()) @updatedAt

  quiz                 Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([quizId, score(sort: Desc)])
}
